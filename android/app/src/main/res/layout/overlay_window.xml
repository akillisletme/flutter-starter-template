<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:background="@drawable/overlay_background"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Drag handle + close -->
    <LinearLayout
        android:id="@+id/overlay_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_overlay_open"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="↗"
            android:textColor="#CDD6F4"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/btn_overlay_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="#A6ADC8"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="#22CDD6F4" />

    <!-- Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btn_overlay_decrement"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/widget_stop_button_bg"
            android:gravity="center"
            android:text="−"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_overlay_increment"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/widget_button_bg"
            android:gravity="center"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
